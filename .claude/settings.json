{
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(jq *)",
      "Bash(du *)",
      "Bash(sort *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pre-commit *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(source:*)",
      "Bash(poetry run:*)",
      "Bash(pytest:*)",
      "Bash(python -c:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(diff:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(tree:*)",
      "Bash(for:*)",
      "Bash(duckdb:*)",
      "Bash(xargs:*)",
      "Bash(git mv:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git rebase:*)",
      "Bash(gh pr:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue:*)",
      "Bash(.venv/bin/python:*)",
      "Bash(rm .github/tmp/*)",
      "Write(sandbox/**)",
      "Edit(sandbox/**)",
      "Write(jupytext.toml)",
      "Edit(jupytext.toml)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(thesis/**)",
      "Write(reports/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "Write(.github/**)",
      "Write(scripts/**)",
      "Write(_current_plan.md)",
      "Write(CHANGELOG.md)",
      "Write(CLAUDE.md)",
      "Write(ARCHITECTURE.md)",
      "Write(README.md)",
      "Write(pyproject.toml)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(thesis/**)",
      "Edit(reports/**)",
      "Edit(docs/**)",
      "Edit(.claude/**)",
      "Edit(.github/**)",
      "Edit(scripts/**)",
      "Edit(_current_plan.md)",
      "Edit(CHANGELOG.md)",
      "Edit(CLAUDE.md)",
      "Edit(ARCHITECTURE.md)",
      "Edit(README.md)",
      "Edit(pyproject.toml)",
      "Write(.pre-commit-config.yaml)",
      "Edit(.pre-commit-config.yaml)"
    ],
    "deny": [
      "Bash(rm -r*)",
      "Bash(git push*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git checkout -- *)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git rebase -i*)",
      "Write(src/**/data/*/raw/**)",
      "Edit(src/**/data/*/raw/**)",
      "Write(docs/thesis/**)",
      "Edit(docs/thesis/**)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/log-subagent.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/log-subagent.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/lint-on-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/guard-write-path.sh"
          }
        ]
      }
    ]
  }
}
