{
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(jq *)",
      "Bash(du *)",
      "Bash(sort *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(source .venv/bin/activate)",
      "Bash(source .venv/bin/activate && poetry:*)",
      "Bash(source .venv/bin/activate && poetry run:*)",
      "Bash(source .venv/bin/activate && poetry run ruff:*)",
      "Bash(source .venv/bin/activate && poetry run mypy:*)",
      "Bash(source .venv/bin/activate && poetry run pytest:*)",
      "Bash(source .venv/bin/activate && poetry run jupyter:*)",
      "Bash(source .venv/bin/activate && poetry run jupytext:*)",
      "Bash(source .venv/bin/activate && poetry run diff-cover:*)",
      "Bash(source .venv/bin/activate && poetry run sc2:*)",
      "Bash(source .venv/bin/activate && poetry run python:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git rebase:*)",
      "Bash(gh pr:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue:*)",
      "Bash(.venv/bin/python:*)",
      "Bash(rm .github/tmp/*)",
      "Write(sandbox/**)",
      "Edit(sandbox/**)",
      "Write(jupytext.toml)",
      "Edit(jupytext.toml)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(thesis/**)",
      "Write(reports/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "Write(.github/**)",
      "Write(scripts/**)",
      "Write(_current_plan.md)",
      "Write(CHANGELOG.md)",
      "Write(CLAUDE.md)",
      "Write(ARCHITECTURE.md)",
      "Write(README.md)",
      "Write(pyproject.toml)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(thesis/**)",
      "Edit(reports/**)",
      "Edit(docs/**)",
      "Edit(.claude/**)",
      "Edit(.github/**)",
      "Edit(scripts/**)",
      "Edit(_current_plan.md)",
      "Edit(CHANGELOG.md)",
      "Edit(CLAUDE.md)",
      "Edit(ARCHITECTURE.md)",
      "Edit(README.md)",
      "Edit(pyproject.toml)"
    ],
    "deny": [
      "Bash(rm -r*)",
      "Bash(git push*)",
      "Bash(git checkout -- *)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git rebase -i*)",
      "Write(src/**/data/*/raw/**)",
      "Edit(src/**/data/*/raw/**)",
      "Write(docs/thesis/**)",
      "Edit(docs/thesis/**)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/log-subagent.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/log-subagent.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/lint-on-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/guard-write-path.sh"
          }
        ]
      }
    ]
  }
}
