{
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(python3 -m pytest*)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(jq *)",
      "Bash(du *)",
      "Bash(sort *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(thesis/**)",
      "Write(reports/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "Write(scripts/**)",
      "Write(_current_plan.md)",
      "Write(CHANGELOG.md)",
      "Write(CLAUDE.md)",
      "Write(ARCHITECTURE.md)",
      "Write(README.md)",
      "Write(pyproject.toml)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(thesis/**)",
      "Edit(reports/**)",
      "Edit(docs/**)",
      "Edit(.claude/**)",
      "Edit(scripts/**)",
      "Edit(_current_plan.md)",
      "Edit(CHANGELOG.md)",
      "Edit(CLAUDE.md)",
      "Edit(ARCHITECTURE.md)",
      "Edit(README.md)",
      "Edit(pyproject.toml)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git checkout -- *)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git rebase*)",
      "Write(src/**/data/*/raw/**)",
      "Edit(src/**/data/*/raw/**)",
      "Read(tmp/**)",
      "Write(tmp/**)",
      "Edit(tmp/**)",
      "Write(docs/thesis/**)",
      "Edit(docs/thesis/**)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/log-subagent.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/log-subagent.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/lint-on-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/guard-write-path.sh"
          }
        ]
      }
    ]
  }
}
